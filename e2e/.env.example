# Playwright browser origin
BASE_URL=http://localhost:3000

# Enable only for the documented real Keycloak gate.
KEYCLOAK_E2E=0

# The username/password are generated into ignored dev/keycloak/.env by:
#   ./scripts/keycloak-dev.sh up
# Source that file instead of writing credentials here.
KEYCLOAK_TEST_USERNAME=
KEYCLOAK_TEST_PASSWORD=
