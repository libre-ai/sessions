# === Core Server ===

# Database
DATABASE_URL=postgres://postgres:presto@localhost:5432/postgres

# Cache/Fanout
REDIS_URL=redis://localhost:6379/

# Local capability authority (generate at runtime; never commit the value)
BISCUIT_PRIVATE_KEY=<paste output of: presto-server keygen>

# Owner OIDC (all three + explicit single-instance acknowledgement required).
# Owner auth currently refuses DATABASE_URL/REDIS_URL; unset those shared adapters
# for this development mode. Omit all OIDC_* variables to disable owner auth.
# OWNER_AUTH_SINGLE_INSTANCE=1
# OIDC_ISSUER=http://localhost:8081/realms/rumble-lm-dev
# OIDC_CLIENT_ID=rumble-lm-owner
# OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# RAG (optional)
AI_BASE_URL=http://localhost:8000/v1
AI_API_KEY=<api-key>

# === E2E Tests (see e2e/.env.example for details) ===

# For Playwright: base URL the test browser navigates to
BASE_URL=http://localhost:3000
